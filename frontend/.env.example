# i18n 翻译自动化 OpenAI 模型配置
# API 密钥
OPENAI_API_KEY=sk-xxxxxxxxxx
# OpenAI 接口代理
OPENAI_PROXY_URL=https://example.com/v1
# 翻译使用的模型
OPENAI_MODEL_NAME=gpt-4o

# ============================================================
# InsForge SDK 配置（自托管模式）
# ============================================================
# InsForge App 地址 — SDK 通过此地址代理所有请求（数据库、认证、存储、函数）
VITE_INSFORGE_URL=http://172.16.100.211:7130
# InsForge 匿名密钥 — 从 Dashboard Settings → API 页面获取
VITE_INSFORGE_ANON_KEY=

# ============================================================
# AstronRPA 保留服务配置
# ============================================================
# OpenResty 网关地址（robot-service、resource-service、ai-service、openapi-service）
VITE_RPA_SERVICES_URL=http://localhost:32742

# ============================================================
# 已移除的配置（不再需要）
# ============================================================
# VITE_POSTGREST_URL — 不再直连 PostgREST，SDK 通过 InsForge App (7130) 代理
# VITE_CASDOOR_URL — 不再使用 Casdoor 认证
# VITE_INSFORGE_AUTH_URL — 不再直连 Auth 服务，SDK 自动管理认证